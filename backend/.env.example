# ─── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database (RDS) ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://db_user:db_password@rds-endpoint.amazonaws.com:5432/lab_borrowing"

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-super-secret-value
JWT_EXPIRES_IN=1d

# ─── CORS ──────────────────────────────────────────────────────────────────
# Set to your EC2 public IP (or domain) on the server
FRONTEND_ORIGIN=http://localhost:5173

# ─── AWS SNS ───────────────────────────────────────────────────────────────
# IMPORTANT: AWS_REGION must match the region in your Topic ARN.
# Example ARN region: arn:aws:sns:<REGION>:<ACCOUNT_ID>:<TOPIC_NAME>
AWS_REGION=us-east-1
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:LabEquipmentAlerts

# Leave AWS credentials empty when running on EC2 with an IAM Role attached.
# Only fill these in for local development or explicit key-based auth.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
