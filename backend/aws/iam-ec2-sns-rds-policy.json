{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPublishToBorrowingTopic",
      "Effect": "Allow",
      "Action": [
        "sns:Publish"
      ],
      "Resource": "arn:aws:sns:ap-south-1:123456789012:lab-borrowing-alerts"
    },
    {
      "Sid": "AllowTopicMetadataRead",
      "Effect": "Allow",
      "Action": [
        "sns:GetTopicAttributes"
      ],
      "Resource": "arn:aws:sns:ap-south-1:123456789012:lab-borrowing-alerts"
    },
    {
      "Sid": "AllowDescribeRdsForHealthChecks",
      "Effect": "Allow",
      "Action": [
        "rds:DescribeDBInstances",
        "rds:DescribeDBClusters"
      ],
      "Resource": "*"
    }
  ]
}
